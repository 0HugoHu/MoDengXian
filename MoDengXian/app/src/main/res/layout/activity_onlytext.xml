<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/Text_Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="32dp"
        android:adjustViewBounds="true"
        android:maxHeight="25dp"
        android:text="爱国豆腐干那你搞摩斯"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/Text_SubTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/Text_Title"
        android:layout_alignLeft="@id/Text_Title"
        android:adjustViewBounds="true"
        android:maxHeight="20dp"
        android:text="奥斯迪广安而过"
        android:textColor="#FF616161" />

    <TextView
        android:id="@+id/Text_Content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/Text_SubTitle"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:text="阿二哥啊贵哦你搜诶饿哦啊rigid方面公司" />

    <TextView
        android:id="@+id/Text_Content2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/Text_Content"
        android:layout_alignStart="@+id/Text_Content"
        android:layout_marginRight="10dp"
        android:text="爱人各大佛ing色日哦地没发过" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_below="@id/Text_Content2"
        android:orientation="horizontal">

        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginBottom="10dp"
            android:layout_alignParentRight="true"
            android:id="@+id/btnNext"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/next"/>


        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginBottom="10dp"
            android:background="@null"
            android:layout_toLeftOf="@+id/btnNext"
            android:id="@+id/btnLike"
            android:scaleType="fitCenter"
            android:src="@drawable/like"/>


        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginBottom="10dp"
            android:id="@+id/btnDislike"
            android:layout_toLeftOf="@+id/btnLike"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/dislike"/>


        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_marginBottom="10dp"
            android:layout_height="25dp"
            android:id="@+id/btnPrevious"
            android:layout_toLeftOf="@+id/btnDislike"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/previous"/>


    </RelativeLayout>

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginTop="10dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="7dp"
        android:background="@drawable/cross" />



</RelativeLayout>