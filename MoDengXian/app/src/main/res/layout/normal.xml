<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:layout_width="27dp"
        android:src="@drawable/icon"
        android:adjustViewBounds="true"
        android:maxHeight="27dp"
        android:layout_marginTop="4dp"
        android:scaleType="centerInside"
        android:maxWidth="27dp"
        android:id="@+id/Normal_Icon"
        android:layout_alignParentLeft="true"
        android:layout_marginLeft="30dp"
        android:layout_height="27dp" />


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:layout_toRightOf="@id/Normal_Icon"
        android:text="投一投"
        android:clickable="true"
        android:textColor="#424242"
        android:gravity="center"
        android:textSize="15sp"
        android:id="@+id/Normal_Game"
        android:layout_marginLeft="30dp"/>


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:gravity="center"
        android:clickable="true"
        android:textSize="15sp"
        android:textColor="#424242"
        android:layout_toRightOf="@id/Normal_Game"
        android:text="阅读"
        android:id="@+id/Normal_Reading"
        android:layout_marginLeft="35dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:gravity="center"
        android:clickable="true"
        android:textSize="15sp"
        android:layout_toRightOf="@id/Normal_Reading"
        android:text="收藏"
        android:textColor="#424242"
        android:id="@+id/Normal_Favourite"
        android:layout_marginLeft="35dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="35dp"
        android:gravity="center"
        android:textSize="15sp"
        android:layout_toRightOf="@id/Normal_Favourite"
        android:text="放松"
        android:clickable="true"
        android:textColor="#424242"
        android:id="@+id/Normal_Relax"
        android:layout_marginLeft="35dp"/>
</RelativeLayout>
