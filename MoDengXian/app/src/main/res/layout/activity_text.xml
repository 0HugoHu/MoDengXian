<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/Text_Title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="32dp"
        android:adjustViewBounds="true"
        android:maxHeight="25dp"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:maxHeight="20dp"
        android:layout_below="@id/Text_Title"
        android:layout_alignLeft="@id/Text_Title"
        android:textColor="#FF616161"
        android:id="@+id/Text_SubTitle"/>

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:adjustViewBounds="true"
        android:maxHeight="100dp"
        android:maxWidth="100dp"
        android:layout_below="@id/Text_SubTitle"
        android:layout_alignLeft="@id/Text_Title"
        android:layout_marginTop="10dp"
        android:id="@+id/Text_Img"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/Text_SubTitle"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="8dp"
        android:layout_toRightOf="@id/Text_Img"
        android:layout_marginRight="10dp"
        android:id="@+id/Text_Content"/>

    <TextView
        android:id="@+id/Text_Content2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="10dp"
        android:layout_marginTop="5dp"
        android:layout_alignStart="@+id/Text_Img"
        android:layout_below="@+id/Text_Img"
        android:text="这很有可能是意大利人里皮最后一场执教中国队的比赛。银狐在2016年10月牵手中国男足，在2018年俄罗斯世界杯预选赛上带给了危急中的中国队以希望。" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_below="@id/Text_Content2"
        android:orientation="horizontal">

        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginBottom="10dp"
            android:layout_alignParentRight="true"
            android:id="@+id/btnNext"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/next"/>


        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginBottom="10dp"
            android:background="@null"
            android:layout_toLeftOf="@+id/btnNext"
            android:id="@+id/btnLike"
            android:scaleType="fitCenter"
            android:src="@drawable/like"/>


        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginBottom="10dp"
            android:id="@+id/btnDislike"
            android:layout_toLeftOf="@+id/btnLike"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/dislike"/>


        <ImageButton
            android:layout_marginEnd="50dp"
            android:layout_width="25dp"
            android:layout_marginBottom="10dp"
            android:layout_height="25dp"
            android:id="@+id/btnPrevious"
            android:layout_toLeftOf="@+id/btnDislike"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/previous"/>


    </RelativeLayout>

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginTop="10dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="7dp"
        android:background="@drawable/cross" />



</RelativeLayout>